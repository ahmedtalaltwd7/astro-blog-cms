{
  "name": "celestial-comet",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "node ./node_modules/astro/astro.js build",
    "preview": "vercel dev",
