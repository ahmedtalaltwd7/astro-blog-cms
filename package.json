    "fabric": "^7.3.1",
    "marked": "^17.0.5",
    "preact": "^10.29.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "nodemon": "^3.0.1",
    "tailwindcss": "^3.4.19",
    "vercel": "^53.1.0"
  }
}
