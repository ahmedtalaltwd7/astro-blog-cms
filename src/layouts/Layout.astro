---
import "../styles/global.css";
import { readSiteConfig } from "../lib/site-config.js";

const { title = "Astro Blog", description } = Astro.props;
const siteConfig = await readSiteConfig();
const headerStyle = [
	`--site-header-bg: ${siteConfig.headerBackgroundColor};`,
	`--site-header-text: ${siteConfig.headerTextColor};`,
	`--site-brand-text: ${siteConfig.headerBrandTextColor};`,
	`--site-header-link: ${siteConfig.headerLinkColor};`,
	`--site-header-link-hover: ${siteConfig.headerLinkHoverColor};`,
	`--site-header-border: ${siteConfig.headerBorderColor};`,
].join(" ");
const footerStyle = [
	`--site-footer-bg: ${siteConfig.footerBackgroundColor};`,
	`--site-footer-text: ${siteConfig.footerTextColor};`,
	`--site-footer-border: ${siteConfig.footerBorderColor};`,
	`--site-footer-link: ${siteConfig.footerLinkColor};`,
].join(" ");
const headerLinkClass = `site-nav-link link-style-${siteConfig.headerLinkStyle} rounded-md px-3 py-2 font-medium`;
const footerLinks = siteConfig.footerLinks.length > 0 ? siteConfig.footerLinks : siteConfig.navLinks;
const siteIconUrl = siteConfig.iconUrl || "/favicon.svg";
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href={siteIconUrl} />
		<meta name="generator" content={Astro.generator} />
		{description && <meta name="description" content={description} />}
		<script is:inline>
			(() => {
				const storageKey = "astro-blog-theme";
				let storedTheme = null;

				try {
					storedTheme = localStorage.getItem(storageKey);
				} catch {
					storedTheme = null;
				}

				const theme = storedTheme === "dark" ? "dark" : "light";
				document.documentElement.classList.toggle("dark", theme === "dark");
				document.documentElement.dataset.theme = theme;
			})();
		</script>
		<title>{title}</title>
	</head>
	<body class="bg-gray-50">
		<!-- Navigation -->
		<nav class="site-header sticky top-0 z-50 shadow-md" style={headerStyle}>
			<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
				<div class="site-header-inner grid min-h-16 grid-cols-[minmax(0,1fr)_auto] items-center gap-4 py-3 transition-all duration-300 md:grid-cols-[auto_1fr_auto]">
					<div class="flex items-center justify-start">
						<a href="/" class="flex min-w-0 items-center space-x-2">
							{siteConfig.logoUrl && <img src={siteConfig.logoUrl} alt="Logo" class="h-8 w-8 object-contain" />}
							<span class="truncate text-xl font-bold" style="color: var(--site-brand-text);">{siteConfig.brandName}</span>
						</a>
					</div>
					<div class="hidden items-center justify-center gap-2 md:flex">
						{siteConfig.navLinks.map((link) => (
							<a href={link.href} class={headerLinkClass}>{link.label}</a>
						))}
					</div>
					<div class="hidden items-center justify-end space-x-3 md:flex">
						<button
							type="button"
							data-theme-toggle
							class="theme-toggle inline-flex items-center gap-2 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 shadow-sm transition hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
							aria-label="Switch to dark theme"
							aria-pressed="false"
						>
							<svg
								class="theme-toggle-moon h-4 w-4"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								xmlns="http://www.w3.org/2000/svg"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"
								></path>
							</svg>
							<svg
								class="theme-toggle-sun h-4 w-4"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								xmlns="http://www.w3.org/2000/svg"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.36 6.36-.7-.7M6.34 6.34l-.7-.7m12.02 0-.7.7M6.34 17.66l-.7.7M16 12a4 4 0 11-8 0 4 4 0 018 0z"
								></path>
							</svg>
							<span data-theme-toggle-label>Dark</span>
						</button>
						<a href="/admin" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 font-medium">
							Admin Editor
						</a>
					</div>
					<button
						type="button"
						data-mobile-menu-toggle
						class="inline-flex h-11 w-11 items-center justify-center rounded-md border border-gray-300 bg-white text-gray-700 shadow-sm transition hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 md:hidden"
						aria-controls="mobile-site-menu"
						aria-expanded="false"
						aria-label="Open navigation menu"
					>
						<svg
							class="h-5 w-5"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
							xmlns="http://www.w3.org/2000/svg"
							aria-hidden="true"
						>
							<path
								data-mobile-menu-icon-open
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M4 6h16M4 12h16M4 18h16"
							></path>
							<path
								data-mobile-menu-icon-close
								class="hidden"
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M6 18 18 6M6 6l12 12"
							></path>
						</svg>
					</button>
				</div>
				<div id="mobile-site-menu" data-mobile-menu class="hidden border-t py-3 text-center md:hidden" style={`border-color: ${siteConfig.headerBorderColor};`}>
					<div class="flex flex-col items-center gap-2">
						{siteConfig.navLinks.map((link) => (
							<a href={link.href} class={`${headerLinkClass} block w-full max-w-xs px-3 py-2 text-center`}>{link.label}</a>
						))}
					</div>
					<div class="mx-auto mt-3 grid max-w-xs gap-2 border-t pt-3" style={`border-color: ${siteConfig.headerBorderColor};`}>
						<button
							type="button"
							data-theme-toggle
							class="theme-toggle inline-flex w-full items-center justify-center gap-2 rounded-md border border-gray-300 bg-white px-3 py-2 text-sm font-medium text-gray-700 shadow-sm transition hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
							aria-label="Switch to dark theme"
							aria-pressed="false"
						>
							<svg
								class="theme-toggle-moon h-4 w-4"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								xmlns="http://www.w3.org/2000/svg"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"
								></path>
							</svg>
							<svg
								class="theme-toggle-sun h-4 w-4"
								fill="none"
								stroke="currentColor"
								viewBox="0 0 24 24"
								xmlns="http://www.w3.org/2000/svg"
							>
								<path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.36 6.36-.7-.7M6.34 6.34l-.7-.7m12.02 0-.7.7M6.34 17.66l-.7.7M16 12a4 4 0 11-8 0 4 4 0 018 0z"
								></path>
							</svg>
							<span data-theme-toggle-label>Dark</span>
						</button>
						<a href="/admin" class="rounded-lg bg-blue-600 px-4 py-2 text-center font-medium text-white hover:bg-blue-700">
							Admin Editor
						</a>
					</div>
				</div>
			</div>
		</nav>

		<slot />

		<!-- Footer -->
		<footer class="site-footer mt-16 border-t" style={footerStyle}>
			<div class="max-w-7xl mx-auto py-8 px-4 sm:px-6 lg:px-8">
				<div class="text-center">
					{siteConfig.footerShowLogo && siteConfig.logoUrl && (
						<img src={siteConfig.logoUrl} alt="" class="mx-auto mb-3 h-8 w-8 object-contain" />
					)}
					<div class="mb-4 flex flex-wrap justify-center gap-4 text-sm font-medium">
						{footerLinks.map((link) => (
							<a href={link.href} class="site-footer-link">{link.label}</a>
						))}
					</div>
					<p>{siteConfig.footerText}</p>
					<p class="mt-2 text-sm opacity-80">{siteConfig.footerSubtext}</p>
				</div>
			</div>
		</footer>
		<script is:inline>
			(() => {
				const storageKey = "astro-blog-theme";
				const root = document.documentElement;
				const toggles = document.querySelectorAll("[data-theme-toggle]");

				function getTheme() {
					return root.classList.contains("dark") ? "dark" : "light";
				}

				function setTheme(theme) {
					const nextTheme = theme === "dark" ? "dark" : "light";
					root.classList.toggle("dark", nextTheme === "dark");
					root.dataset.theme = nextTheme;

					try {
						localStorage.setItem(storageKey, nextTheme);
					} catch {
						// Theme still changes for this visit if storage is unavailable.
					}

					toggles.forEach((toggle) => {
						const label = toggle.querySelector("[data-theme-toggle-label]");
						const isDark = nextTheme === "dark";
						toggle.setAttribute("aria-pressed", String(isDark));
						toggle.setAttribute(
							"aria-label",
							isDark ? "Switch to light theme" : "Switch to dark theme",
						);

						if (label) {
							label.textContent = isDark ? "Light" : "Dark";
						}
					});
				}

				toggles.forEach((toggle) => {
					toggle.addEventListener("click", () => {
						setTheme(getTheme() === "dark" ? "light" : "dark");
					});
				});

				setTheme(getTheme());

				const mobileMenu = document.querySelector("[data-mobile-menu]");
				const mobileMenuToggle = document.querySelector("[data-mobile-menu-toggle]");
				const mobileOpenIcon = document.querySelector("[data-mobile-menu-icon-open]");
				const mobileCloseIcon = document.querySelector("[data-mobile-menu-icon-close]");

				function setMobileMenu(open) {
					if (!mobileMenu || !mobileMenuToggle) return;

					mobileMenu.classList.toggle("hidden", !open);
					mobileMenuToggle.setAttribute("aria-expanded", String(open));
					mobileMenuToggle.setAttribute(
						"aria-label",
						open ? "Close navigation menu" : "Open navigation menu",
					);
					mobileOpenIcon?.classList.toggle("hidden", open);
					mobileCloseIcon?.classList.toggle("hidden", !open);
				}

				mobileMenuToggle?.addEventListener("click", () => {
					setMobileMenu(mobileMenu?.classList.contains("hidden"));
				});

				mobileMenu?.querySelectorAll("a").forEach((link) => {
					link.addEventListener("click", () => setMobileMenu(false));
				});

				window.addEventListener("resize", () => {
					if (window.matchMedia("(min-width: 768px)").matches) {
						setMobileMenu(false);
					}
				});

				window.addEventListener("keydown", (event) => {
					if (event.key === "Escape") {
						setMobileMenu(false);
					}
				});

				const header = document.querySelector(".site-header");
				function updateHeader() {
					header?.classList.toggle("is-scrolled", window.scrollY > 12);
				}

				updateHeader();
				window.addEventListener("scroll", updateHeader, { passive: true });
			})();
		</script>
	</body>
</html>
