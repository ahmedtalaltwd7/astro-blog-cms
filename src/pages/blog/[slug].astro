---
import Layout from "../../layouts/Layout.astro";
import fs from "node:fs/promises";
import path from "node:path";
import { marked } from "marked";
export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/404");
}

// Normalize slug: allow requests like /blog/new-post.md and /blog/new-post
const originalSlug = String(slug);
const normalized = originalSlug.replace(/\.md$/i, "");

// If the user requested the .md URL, redirect to the clean URL to avoid
// exposing raw markdown and keep canonical URLs consistent.
if (originalSlug.toLowerCase().endsWith(".md")) {
  return Astro.redirect(`/blog/${normalized}`, 301);
}

// Sanitize slug to prevent path traversal
const safeSlug = normalized.replace(/[^a-zA-Z0-9\-_]/g, "");

// Import markdown modules from the content folder so Astro compiles them
const postModules = import.meta.glob<{
  frontmatter: Record<string, any>;
  default: any;
}>("../../content/blog/*.md");
let frontmatter: Record<string, any> = {};
let Content: any = null;
let htmlContent = "";
const markdownContentClass = [
  "max-w-none text-gray-800",
  "[&_a]:text-blue-700 [&_a]:underline",
  "[&_blockquote]:mb-4 [&_blockquote]:border-l-4 [&_blockquote]:border-blue-200 [&_blockquote]:bg-blue-50 [&_blockquote]:px-4 [&_blockquote]:py-2",
  "[&_code]:rounded [&_code]:bg-gray-100 [&_code]:px-1",
  "[&_h1]:mb-4 [&_h1]:text-3xl [&_h1]:font-bold",
  "[&_h2]:mb-3 [&_h2]:mt-6 [&_h2]:text-2xl [&_h2]:font-semibold",
  "[&_h3]:mb-2 [&_h3]:mt-5 [&_h3]:text-xl [&_h3]:font-semibold",
  "[&_img]:my-6 [&_img]:rounded-lg",
  "[&_li]:ml-5",
  "[&_ol]:mb-4 [&_ol]:list-decimal",
  "[&_p]:mb-4",
  "[&_pre]:mb-4 [&_pre]:overflow-auto [&_pre]:rounded-lg [&_pre]:bg-gray-900 [&_pre]:p-4",
  "[&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:text-gray-100",
  "[&_table]:mb-4 [&_table]:w-full [&_table]:border-collapse",
  "[&_td]:border [&_td]:border-gray-200 [&_td]:p-2",
  "[&_th]:border [&_th]:border-gray-200 [&_th]:bg-gray-50 [&_th]:p-2",
  "[&_ul]:mb-4 [&_ul]:list-disc",
].join(" ");

for (const [filePath, resolver] of Object.entries(postModules)) {
  if (filePath.endsWith(`${safeSlug}.md`)) {
    try {
      const mod = await resolver();
      frontmatter = mod.frontmatter || {};
      Content = mod.default;
      break;
    } catch (e) {
      // resolver may fail in dev if file was added after startup — ignore and fallback
    }
  }
}

// If we couldn't load the compiled markdown component (e.g. file added at runtime),
// read and render the markdown file directly so posts show immediately without rebuild.
if (!Content) {
  const filePath = path.join(
    process.cwd(),
    "src",
    "content",
    "blog",
    `${safeSlug}.md`,
  );
  try {
    const raw = await fs.readFile(filePath, "utf-8");
    // simple frontmatter parse
    function parseFrontmatter(content: string) {
      const lines = content.split("\n");
      if (lines[0]?.trim() === "---") {
        let endIndex = -1;
        for (let i = 1; i < lines.length; i++) {
          if (lines[i]?.trim() === "---") {
            endIndex = i;
            break;
          }
        }
        if (endIndex !== -1) {
          const frontmatterLines = lines.slice(1, endIndex);
          const body = lines
            .slice(endIndex + 1)
            .join("\n")
            .trimStart();
          const front: Record<string, any> = {};
          for (const line of frontmatterLines) {
            const match = line.match(/^(\w+):\s*(.*)$/);
            if (match) {
              const key = match[1];
              let value: any = match[2].trim();
              if (
                (value.startsWith('"') && value.endsWith('"')) ||
                (value.startsWith("'") && value.endsWith("'"))
              ) {
                value = value.slice(1, -1);
              }
              if (value.startsWith("[") && value.endsWith("]")) {
                value = value
                  .slice(1, -1)
                  .split(",")
                  .map((t: string) => t.trim().replace(/^['\"]|['\"]$/g, ""))
                  .filter(Boolean);
              }
              front[key] = value;
            }
          }
          return { frontmatter: front, body };
        }
      }
      return { frontmatter: {}, body: content };
    }

    const parsed = parseFrontmatter(raw);
    frontmatter = parsed.frontmatter || {};
    marked.setOptions({ gfm: true, breaks: false });
    htmlContent = await marked(parsed.body || parsed);
  } catch (err) {
    return Astro.redirect("/404");
  }
}
---

<Layout title={frontmatter.title || `Blog Post`}>
  <div class="min-h-screen bg-gray-50 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <article class="bg-white shadow-lg rounded-xl overflow-hidden">
        {/* Hero image */}
        {
          frontmatter.image ? (
            <div class="h-64 relative overflow-hidden">
              <img
                src={frontmatter.image}
                alt={frontmatter.title}
                class="w-full h-full object-cover"
              />
              <div class="absolute inset-0 bg-black bg-opacity-40 flex items-center justify-center">
                <h1 class="text-4xl md:text-5xl font-bold text-white text-center px-4">
                  {frontmatter.title}
                </h1>
              </div>
            </div>
          ) : (
            <div class="h-64 bg-gradient-to-r from-blue-500 to-purple-600 flex items-center justify-center">
              <h1 class="text-4xl md:text-5xl font-bold text-white text-center px-4">
                {frontmatter.title}
              </h1>
            </div>
          )
        }

        <div class="p-8 md:p-12">
          {/* Metadata */}
          <div class="flex flex-wrap items-center gap-4 mb-8 text-gray-600">
            {
              frontmatter.pubDate && (
                <div class="flex items-center">
                  <svg
                    class="w-5 h-5 mr-2"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <time datetime={frontmatter.pubDate}>
                    {frontmatter.pubDate}
                  </time>
                </div>
              )
            }

            {
              frontmatter.author && (
                <div class="flex items-center">
                  <svg
                    class="w-5 h-5 mr-2"
                    fill="currentColor"
                    viewBox="0 0 20 20"
                    xmlns="http://www.w3.org/2000/svg"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span>{frontmatter.author}</span>
                </div>
              )
            }

            {
              frontmatter.tags &&
                Array.isArray(frontmatter.tags) &&
                frontmatter.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2">
                    {frontmatter.tags.map((tag: string) => (
                      <span class="px-3 py-1 bg-blue-100 text-blue-800 text-sm font-medium rounded-full">
                        {tag}
                      </span>
                    ))}
                  </div>
                )
            }
          </div>

          {/* Description */}
          {
            frontmatter.description && (
              <p class="text-xl text-gray-700 mb-8 italic border-l-4 border-blue-500 pl-4">
                {frontmatter.description}
              </p>
            )
          }

          {/* Rendered Markdown Content */}
          {
            Content ? (
              <div class={markdownContentClass}>
                <Content />
              </div>
            ) : (
              <div class={markdownContentClass} set:html={htmlContent} />
            )
          }

          {/* Back to blog link */}
          <div class="mt-12 pt-8 border-t border-gray-200">
            <a
              href="/admin"
              class="inline-flex items-center text-blue-600 hover:text-blue-800 font-medium"
            >
              <svg
                class="w-5 h-5 mr-2"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M11 15l-3-3m0 0l3-3m-3 3h8M3 12a9 9 0 1118 0 9 9 0 01-18 0z"
                ></path>
              </svg>
              Back to Editor
            </a>
            <a
              href="/"
              class="inline-flex items-center text-gray-600 hover:text-gray-800 font-medium ml-6"
            >
              <svg
                class="w-5 h-5 mr-2"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"
                ></path>
              </svg>
              Home
            </a>
          </div>
        </div>
      </article>
    </div>
  </div>
</Layout>
