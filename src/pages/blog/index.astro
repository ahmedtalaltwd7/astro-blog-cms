---
import Layout from "../../layouts/Layout.astro";

// We'll fetch posts client-side and append more on demand.
const limit = 6;
---

<Layout title="Blog Posts">
  <div class="min-h-screen bg-gray-50 py-12">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">
          Blog Posts
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          A collection of blog posts created with the admin editor. Each post is
          stored as a markdown file in <code
            class="bg-gray-100 px-2 py-1 rounded">src/pages/blog/</code
          >.
        </p>
        <a
          href="/admin"
          class="inline-flex items-center mt-6 px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
        >
          <svg
            class="w-5 h-5 mr-2"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
          </svg>
          Create New Post
        </a>
      </div>

      <div class="mb-8 max-w-xl mx-auto">
        <label for="post-search" class="sr-only">Search blog posts by title</label>
        <div class="relative">
          <div
            class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none"
          >
            <svg
              class="h-5 w-5 text-gray-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M21 21l-4.35-4.35m1.85-5.15a7 7 0 11-14 0 7 7 0 0114 0z"
              ></path>
            </svg>
          </div>
          <input
            id="post-search"
            type="search"
            placeholder="Search blog posts by title..."
            class="block w-full rounded-md border border-gray-300 bg-white py-3 pl-12 pr-4 text-gray-900 shadow-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-500"
            autocomplete="off"
          />
        </div>
      </div>

      <!-- Container for posts (will be populated by JavaScript) -->
      <div
        id="posts-container"
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"
      >
        <!-- Loading indicator -->
        <div id="loading" class="col-span-full text-center py-12">
          <div
            class="inline-block animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-blue-500"
          >
          </div>
          <p class="mt-4 text-gray-600">Loading posts...</p>
        </div>
        <!-- Posts will be inserted here -->
      </div>

      <!-- Empty state (hidden by default) -->
      <div id="empty-state" class="hidden text-center py-16">
        <svg
          class="mx-auto h-16 w-16 text-gray-400"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
          xmlns="http://www.w3.org/2000/svg"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
          ></path>
        </svg>
        <h3 class="mt-4 text-xl font-medium text-gray-900">
          <span id="empty-title">No blog posts yet</span>
        </h3>
        <p id="empty-message" class="mt-2 text-gray-500 max-w-md mx-auto">
          Get started by creating your first blog post using the admin editor.
        </p>
        <div class="mt-6">
          <a
            href="/admin"
            class="inline-flex items-center px-5 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
          >
            Create First Post
          </a>
        </div>
      </div>

      <!-- Load more control -->
      <div
        id="load-more-wrapper"
        class="hidden mt-12 text-center"
      >
        <button
          id="load-more-btn"
          class="inline-flex items-center justify-center px-6 py-3 border border-gray-300 text-base font-medium rounded-md text-gray-700 bg-white shadow-sm hover:bg-gray-50 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Load More
        </button>
        <p id="load-more-status" class="mt-3 text-sm text-gray-500"></p>
      </div>
    </div>
  </div>

  <script>
    // @ts-nocheck
    (() => {
      /** @type {HTMLElement | null} */
      const postsContainer = document.getElementById("posts-container");
      /** @type {HTMLElement | null} */
      const loadingEl = document.getElementById("loading");
      /** @type {HTMLElement | null} */
      const emptyState = document.getElementById("empty-state");
      /** @type {HTMLElement | null} */
      const loadMoreWrapper = document.getElementById("load-more-wrapper");
      /** @type {HTMLButtonElement | null} */
      const loadMoreBtn = document.getElementById("load-more-btn");
      /** @type {HTMLElement | null} */
      const loadMoreStatus = document.getElementById("load-more-status");
      /** @type {HTMLInputElement | null} */
      const searchInput = document.getElementById("post-search");
      /** @type {HTMLElement | null} */
      const emptyTitle = document.getElementById("empty-title");
      /** @type {HTMLElement | null} */
      const emptyMessage = document.getElementById("empty-message");

      // Type guard for null elements
      if (
        !postsContainer ||
        !loadingEl ||
        !emptyState ||
        !loadMoreWrapper ||
        !loadMoreBtn ||
        !loadMoreStatus ||
        !searchInput ||
        !emptyTitle ||
        !emptyMessage
      ) {
        console.error("Required DOM elements not found");
        return;
      }

      let currentPage = 0;
      const limit = 6;
      let totalPages = 1;
      let totalPosts = 0;
      let searchTerm = "";
      let isLoading = false;
      let searchTimeout;
      const listStateKey = "astro-blog-post-list-state";

      if ("scrollRestoration" in history) {
        history.scrollRestoration = "manual";
      }

      function readListState() {
        try {
          const savedState = JSON.parse(
            sessionStorage.getItem(listStateKey) || "null",
          );

          if (!savedState || typeof savedState !== "object") {
            return null;
          }

          return {
            currentPage: Math.max(0, Number(savedState.currentPage) || 0),
            scrollY: Math.max(0, Number(savedState.scrollY) || 0),
            searchTerm: String(savedState.searchTerm || ""),
            pendingRestore: Boolean(savedState.pendingRestore),
          };
        } catch {
          return null;
        }
      }

      function saveListState(scrollY = window.scrollY, pendingRestore = false) {
        try {
          sessionStorage.setItem(
            listStateKey,
            JSON.stringify({
              currentPage,
              scrollY,
              searchTerm,
              pendingRestore,
            }),
          );
        } catch {
          // Browsing still works if session storage is unavailable.
        }
      }

      /**
       * @typedef {Object} Post
       * @property {string} slug
       * @property {string} title
       * @property {string} pubDate
       * @property {string} [description]
       * @property {string[]} [tags]
       * @property {string} [image]
       * @property {string} [thumbnail]
       */

      /**
       * @param {Post} post
       * @returns {string}
       */
      function escapeHtml(value) {
        return String(value || "")
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#039;");
      }

      /**
       * @param {string} tag
       * @returns {string}
       */
      function renderTagLink(tag) {
        const cleanTag = String(tag || "").replace(/^#+/, "").trim();
        if (!cleanTag) return "";

        return `
          <a href="/tags/${encodeURIComponent(cleanTag)}" class="px-3 py-1 bg-blue-100 text-blue-800 text-xs font-medium rounded-full hover:bg-blue-200">
            #${escapeHtml(cleanTag)}
          </a>
        `;
      }

      /**
       * @param {Post} post
       * @returns {string}
       */
      function renderPost(post) {
        const imageUrl = post.thumbnail || post.image;
        const safeTitle = escapeHtml(post.title);
        const safeDescription = escapeHtml(
          post.description || "No description provided.",
        );
        const safePubDate = escapeHtml(post.pubDate);
        const imageHtml = imageUrl
          ? `<img src="${escapeHtml(imageUrl)}" alt="${safeTitle}" class="w-full h-48 object-cover" />`
          : `<div class="h-48 bg-gradient-to-r from-blue-400 to-purple-500"></div>`;
        return `
          <article class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-xl transition-shadow duration-300">
            ${imageHtml}
            <div class="p-6">
              <div class="flex items-center text-sm text-gray-500 mb-3">
                <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                  <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
                </svg>
                <time datetime="${safePubDate}">${safePubDate}</time>
              </div>
              <h2 class="text-xl font-bold text-gray-900 mb-3">
                <a href="/blog/${encodeURIComponent(post.slug)}" class="hover:text-blue-600">${safeTitle}</a>
              </h2>
              <p class="text-gray-600 mb-4">${safeDescription}</p>
              <div class="flex flex-wrap gap-2 mb-4">
                ${(post.tags || [])
                  .map(renderTagLink)
                  .join("")}
              </div>
              <a href="/blog/${encodeURIComponent(post.slug)}" class="inline-flex items-center text-blue-600 hover:text-blue-800 font-medium">
                Read more
                <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </a>
            </div>
          </article>
        `;
      }

      /**
       * @param {number} page
       */
      async function loadPage(
        page,
        append = false,
        requestLimit = limit,
        displayedPage = page,
      ) {
        if (isLoading) return;

        isLoading = true;
        emptyState.classList.add("hidden");
        loadMoreWrapper.classList.add("hidden");

        if (append) {
          loadMoreBtn.disabled = true;
          loadMoreBtn.textContent = "Loading...";
          loadMoreStatus.textContent = "Loading more posts...";
        } else {
          loadingEl.classList.remove("hidden");
          postsContainer.innerHTML = "";
          postsContainer.appendChild(loadingEl);
        }

        try {
          const params = new URLSearchParams({
            page: page.toString(),
            limit: requestLimit.toString(),
          });

          if (searchTerm) {
            params.set("search", searchTerm);
          }

          const response = await fetch(
            `/api/list-posts?${params.toString()}`,
          );
          if (!response.ok) throw new Error("Failed to fetch posts");
          const data = await response.json();

          loadingEl.classList.add("hidden");
          if (loadingEl.parentElement === postsContainer) {
            postsContainer.removeChild(loadingEl);
          }

          if (!append && data.posts.length === 0) {
            currentPage = 0;
            totalPages = 1;
            totalPosts = 0;
            emptyTitle.textContent = searchTerm
              ? "No matching blog posts"
              : "No blog posts yet";
            emptyMessage.textContent = searchTerm
              ? "Try searching for a different blog title."
              : "Get started by creating your first blog post using the admin editor.";
            emptyState.classList.remove("hidden");
            saveListState();
            return;
          }

          const postsHtml = data.posts.map(renderPost).join("");
          if (append) {
            postsContainer.insertAdjacentHTML("beforeend", postsHtml);
          } else {
            postsContainer.innerHTML = postsHtml;
          }

          totalPages = Math.max(1, Math.ceil(data.pagination.total / limit));
          totalPosts = data.pagination.total;
          currentPage = Math.min(displayedPage, totalPages);

          const renderedCount = Math.min(currentPage * limit, totalPosts);
          loadMoreStatus.textContent = `Showing ${renderedCount} of ${totalPosts} posts.`;

          if (currentPage < totalPages) {
            loadMoreBtn.disabled = false;
            loadMoreBtn.textContent = "Load More";
            loadMoreWrapper.classList.remove("hidden");
          }
          saveListState();
        } catch (error) {
          console.error("Error loading posts:", error);
          loadingEl.classList.add("hidden");
          if (append) {
            loadMoreBtn.disabled = false;
            loadMoreBtn.textContent = "Load More";
            loadMoreStatus.textContent =
              "Failed to load more posts. Please try again.";
            loadMoreWrapper.classList.remove("hidden");
          } else {
            postsContainer.innerHTML =
              '<p class="col-span-full text-center text-red-600">Failed to load posts. Please try again later.</p>';
          }
        } finally {
          isLoading = false;
        }
      }

      loadMoreBtn.addEventListener("click", () => {
        if (currentPage < totalPages) {
          loadPage(currentPage + 1, true);
        }
      });

      postsContainer.addEventListener("click", (event) => {
        const link = event.target.closest("a[href]");
        if (!link) return;

        const url = new URL(link.href, window.location.origin);
        if (url.origin === window.location.origin && url.pathname.startsWith("/blog/")) {
          saveListState(window.scrollY, true);
        }
      });

      searchInput.addEventListener("input", () => {
        window.clearTimeout(searchTimeout);
        searchTimeout = window.setTimeout(() => {
          searchTerm = searchInput.value.trim();
          loadPage(1);
        }, 250);
      });

      window.addEventListener("pagehide", () => {
        const savedState = readListState();
        saveListState(window.scrollY, Boolean(savedState?.pendingRestore));
      });

      window.addEventListener("pageshow", (event) => {
        if (event.persisted) {
          saveListState(window.scrollY, false);
        }
      });

      async function loadInitialPosts() {
        const savedState = readListState();
        if (savedState?.pendingRestore) {
          const pagesToRestore = Math.max(1, savedState.currentPage || 1);
          searchTerm = savedState.searchTerm;
          searchInput.value = searchTerm;

          await loadPage(1, false, pagesToRestore * limit, pagesToRestore);

          requestAnimationFrame(() => {
            window.scrollTo(0, savedState.scrollY);
            saveListState(savedState.scrollY, false);
          });
          return;
        }

        await loadPage(1);
      }

      loadInitialPosts();
    })();
  </script>
</Layout>
